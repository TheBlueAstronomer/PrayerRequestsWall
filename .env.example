# Copy to .env and fill in. Do NOT commit your real .env.

# ── Admin authentication (required) ─────────────────────────────────────────
# Password for the /admin dashboard. Choose a strong, unique value.
# If unset, admin login is disabled and every /api/admin/* route returns 401.
ADMIN_PASSWORD=

# Secret used to sign admin session cookies (HMAC-SHA256). Use a long random
# value, e.g. `openssl rand -base64 48`. If unset, no session can be issued or
# verified, so admin login fails closed.
ADMIN_SESSION_SECRET=

# Optional: admin session lifetime in seconds (default 604800 = 7 days).
# ADMIN_SESSION_TTL_SECONDS=604800

# ── WhatsApp ────────────────────────────────────────────────────────────────
# Default group/chat ID to send prayer requests to (DB settings override this).
WHATSAPP_GROUP_ID=

# Optional: default test group/chat ID (DB settings override this).
# WHATSAPP_TEST_GROUP_ID=

# Optional: WhatsApp client tuning (see src/lib/whatsapp.ts for defaults).
# WA_ACK_TIMEOUT_MS=30000
# WA_QR_MAX_RETRIES=5

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
